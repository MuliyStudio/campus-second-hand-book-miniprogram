/* 整体容器 */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
  width: 100%;
}

/* 顶部导航栏 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: #667eea;
  color: white;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  width: 100%;
}

.header-title {
  font-size: 34rpx;
  font-weight: bold;
}

.header-status {
  display: flex;
  align-items: center;
  font-size: 24rpx;
}

.status-indicator {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.status-indicator.online {
  background-color: #52c41a;
}

.status-indicator.offline {
  background-color: #ff4d4f;
}

.status-text {
  font-size: 24rpx;
}

/* 聊天区域 */
.chat-container {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.chat-messages {
  display: flex;
  flex-direction: column;
  width: 100%;
}

.message-item {
  margin-bottom: 30rpx;
  width: 100%;
  box-sizing: border-box;
}

/* 系统消息 */
.system-message {
  display: flex;
  justify-content: center;
  width: 100%;
}

.system-bubble {
  background-color: #f0f0f0;
  border-radius: 20rpx;
  padding: 15rpx 25rpx;
  max-width: 70%;
  text-align: center;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.1);
  width: fit-content;
}

.system-message .message-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  word-break: break-word;
}

.system-message .message-time {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 5rpx;
}

/* 用户消息 */
.user-message {
  display: flex;
  justify-content: flex-end;
  width: 100%;
}

.user-bubble {
  background-color: #667eea;
  color: white;
  border-radius: 20rpx;
  padding: 15rpx 25rpx;
  max-width: 70%;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.1);
}

.user-message .message-content {
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-word;
}

.user-message .message-time {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 5rpx;
  text-align: right;
}

/* 客服消息 */
.service-message {
  display: flex;
  justify-content: flex-start;
  width: 100%;
}

.service-bubble {
  background-color: white;
  border-radius: 20rpx;
  padding: 15rpx 25rpx;
  max-width: 70%;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.1);
  border: 1rpx solid #eee;
}

.service-message .message-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  word-break: break-word;
}

.service-message .message-time {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 5rpx;
}

/* 加载动画 */
.loading-indicator {
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 20rpx 0;
}

.loading-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #999;
  margin: 0 5rpx;
  animation: bounce 1.5s infinite ease-in-out;
}

.loading-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.loading-dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes bounce {
  0%, 80%, 100% {
    transform: scale(0);
  }
  40% {
    transform: scale(1);
  }
}

/* 快捷问题区域 */
.quick-questions {
  background-color: white;
  padding: 20rpx;
  border-top: 1rpx solid #eee;
  width: 100%;
  box-sizing: border-box;
}

.quick-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.quick-list {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.quick-item {
  background-color: #f0f0f0;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #333;
  box-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.05);
}

.quick-item:active {
  background-color: #e0e0e0;
}

/* 输入区域 */
.input-area {
  background-color: white;
  padding: 20rpx;
  border-top: 1rpx solid #eee;
  width: 100%;
  box-sizing: border-box;
}

.input-container {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 30rpx;
  padding: 10rpx 20rpx;
  width: 100%;
}

.message-input {
  flex: 1;
  height: 60rpx;
  font-size: 28rpx;
  color: #333;
  background-color: transparent;
}

.send-btn {
  background-color: #667eea;
  color: white;
  padding: 10rpx 25rpx;
  border-radius: 25rpx;
  font-size: 26rpx;
  margin-left: 15rpx;
  box-shadow: 0 2rpx 5rpx rgba(102, 126, 234, 0.3);
}

.send-btn[disabled] {
  background-color: #ccc;
  box-shadow: none;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .system-bubble, .user-bubble, .service-bubble {
    max-width: 80%;
  }
}