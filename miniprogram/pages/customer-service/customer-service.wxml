<view class="container">
  <!-- 顶部导航栏 -->
  <view class="header">
    <view class="header-title">在线客服</view>
    <view class="header-status">
      <view class="status-indicator {{serviceStatus === 'online' ? 'online' : 'offline'}}"></view>
      <text class="status-text">{{serviceStatus === 'online' ? '客服在线' : '客服离线'}}</text>
    </view>
  </view>

  <!-- 聊天区域 -->
  <scroll-view 
    class="chat-container" 
    scroll-y="true" 
    scroll-into-view="{{lastMessageId}}"
    scroll-with-animation="true"
  >
    <view class="chat-messages">
      <block wx:for="{{messages}}" wx:key="id">
        <view class="message-item {{item.type}}">
          <!-- 系统消息 -->
          <view wx:if="{{item.type === 'system'}}" class="system-message">
            <view class="message-bubble system-bubble">
              <text class="message-content">{{item.content}}</text>
              <text class="message-time">{{item.time}}</text>
            </view>
          </view>
          
          <!-- 用户消息 -->
          <view wx:elif="{{item.type === 'user'}}" class="user-message">
            <view class="message-bubble user-bubble">
              <text class="message-content">{{item.content}}</text>
              <text class="message-time">{{item.time}}</text>
            </view>
          </view>
          
          <!-- 客服消息 -->
          <view wx:else class="service-message">
            <view class="message-bubble service-bubble">
              <text class="message-content">{{item.content}}</text>
              <text class="message-time">{{item.time}}</text>
            </view>
          </view>
        </view>
      </block>
      
      <!-- 加载动画 -->
      <view wx:if="{{isLoading}}" class="loading-indicator">
        <view class="loading-dot"></view>
        <view class="loading-dot"></view>
        <view class="loading-dot"></view>
      </view>
    </view>
  </scroll-view>

  <!-- 快捷问题区域 -->
  <view class="quick-questions" wx:if="{{showQuickQuestions}}">
    <view class="quick-title">常见问题：</view>
    <view class="quick-list">
      <view 
        class="quick-item" 
        wx:for="{{quickQuestions}}" 
        wx:key="index"
        bindtap="sendQuickQuestion"
        data-content="{{item}}"
      >
        {{item}}
      </view>
    </view>
  </view>

  <!-- 输入区域 -->
  <view class="input-area">
    <view class="input-container">
      <input 
        class="message-input" 
        placeholder="请输入您的问题..." 
        value="{{inputValue}}"
        bindinput="handleInput"
        confirm-type="send"
        bindconfirm="sendMessage"
        maxlength="500"
      />
      <view class="send-btn" bindtap="sendMessage" disabled="{{!inputValue.trim()}}">
        <text>发送</text>
      </view>
    </view>
  </view>
</view>