.container {
  width: 100vw;
  min-height: 100vh;
  background: #f5f5f5;
  overflow-x: hidden;
}

.search-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: white;
  z-index: 100;
  padding: 20rpx 20rpx 0;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
  box-sizing: border-box;
  width: 100vw;
}

.search-box {
  display: flex;
  align-items: center;
  height: 80rpx;
  width: 100%;
  box-sizing: border-box;
}

.back-btn {
  font-size: 40rpx;
  color: #333;
  width: 60rpx;
  text-align: center;
  flex-shrink: 0;
}

.search-input-wrapper {
  flex: 1;
  height: 80rpx;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  margin: 0 15rpx;
  box-sizing: border-box;
  min-width: 0;
}

.search-icon {
  font-size: 30rpx;
  color: #999;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  height: 80rpx;
  min-width: 0;
  box-sizing: border-box;
  background: transparent;
  border: none;
  outline: none;
}

.clear-btn {
  font-size: 30rpx;
  color: #999;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  border-radius: 50%;
  background: #e0e0e0;
  flex-shrink: 0;
  margin-left: 10rpx;
}

.search-btn {
  font-size: 28rpx;
  color: #667eea;
  font-weight: 600;
  padding: 0 20rpx;
  flex-shrink: 0;
}

.suggestions-panel {
  position: fixed;
  top: 120rpx;
  left: 0;
  right: 0;
  background: white;
  z-index: 99;
  border-bottom: 1rpx solid #eee;
  max-height: 500rpx;
  overflow-y: auto;
}

.suggestions-list {
  padding: 10rpx 0;
}

.suggestion-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  transition: background 0.2s;
}

.suggestion-item:active {
  background: #f8f8f8;
}

.suggestion-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.suggestion-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.suggestion-type {
  font-size: 22rpx;
  color: #999;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
}

.result-page {
  padding-top: 120rpx;
  min-height: 100vh;
  box-sizing: border-box;
  width: 100vw;
  overflow-x: hidden;
}

.filter-bar {
  position: fixed;
  top: 120rpx;
  left: 0;
  right: 0;
  height: 80rpx;
  background: white;
  z-index: 99;
  border-bottom: 1rpx solid #eee;
  width: 100vw;
  box-sizing: border-box;
}

.filter-scroll {
  width: 100vw;
  height: 80rpx;
  white-space: nowrap;
  box-sizing: border-box;
  overflow-x: auto;
  overflow-y: hidden;
}

.filter-list {
  display: inline-flex;
  align-items: center;
  height: 80rpx;
  padding: 0 20rpx;
  gap: 40rpx;
  min-width: 100vw;
  box-sizing: border-box;
}

.filter-item {
  display: inline-flex;
  align-items: center;
  height: 80rpx;
  color: #666;
  font-size: 28rpx;
  white-space: nowrap;
  flex-shrink: 0;
  position: relative;
  padding: 0 10rpx;
}

.filter-item.active {
  color: #ff6b6b;
  font-weight: bold;
}

.filter-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 10rpx;
  right: 10rpx;
  height: 4rpx;
  background: #ff6b6b;
  border-radius: 2rpx;
}

.product-list {
  height: calc(100vh - 200rpx);
  padding-top: 80rpx;
  box-sizing: border-box;
  background: #f5f5f5;
  width: 100vw;
  overflow-x: hidden;
}

.result-info {
  padding: 20rpx;
  font-size: 24rpx;
  color: #999;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 0 20rpx 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.product-card {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  width: 100%;
  box-sizing: border-box;
}

.product-img {
  position: relative;
  width: 100%;
  height: 0;
  padding-bottom: 100%;
  overflow: hidden;
  background: #fafafa;
}

.product-img image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.product-status {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: white;
  background: #4CAF50;
  box-shadow: 0 3rpx 10rpx rgba(76, 175, 80, 0.3);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  letter-spacing: 0.5rpx;
  z-index: 2;
}

.product-status.reserved {
  background: #FF9800;
}

.book-condition {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: white;
  box-shadow: 0 3rpx 10rpx rgba(0, 0, 0, 0.2);
  z-index: 2;
}

.condition-new {
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.condition-good {
  background: linear-gradient(135deg, #4CAF50, #45a049);
}

.condition-normal {
  background: linear-gradient(135deg, #ff9800, #f57c00);
}

.book-info {
  padding: 20rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  background: #ffffff;
}

.book-title-row {
  width: 100%;
  margin-bottom: 2rpx;
}

.book-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  letter-spacing: 0.5rpx;
  min-height: 40rpx;
}

.match-tag {
  display: inline-block;
  font-size: 20rpx;
  color: #667eea;
  background: #eef2ff;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  margin-bottom: 8rpx;
  width: fit-content;
}

.book-price-section {
  width: 100%;
  margin-top: 8rpx;
  padding-top: 8rpx;
  border-top: 1rpx solid #eef2ff;
}

.book-price {
  font-size: 34rpx;
  color: #ff6b6b;
  font-weight: 800;
  letter-spacing: 1rpx;
  line-height: 1.2;
}

.seller-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
  padding-top: 8rpx;
  border-top: 1rpx solid #eef2ff;
}

.seller-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 2rpx solid #eef2ff;
  flex-shrink: 0;
}

.seller-details {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.seller-name {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.seller-location {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.location-icon {
  font-size: 20rpx;
}

.location-text {
  font-size: 22rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.load-more {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 28rpx;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.loading-spinner {
  width: 50rpx;
  height: 50rpx;
  border: 4rpx solid #eef2ff;
  border-top: 4rpx solid #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #667eea;
}

.no-more {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 28rpx;
}

.no-result {
  text-align: center;
  padding: 100rpx 0;
  width: 100vw;
  box-sizing: border-box;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  color: #ccc;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #999;
}

.history-page {
  padding-top: 120rpx;
  min-height: 100vh;
  background: white;
  width: 100vw;
  box-sizing: border-box;
  overflow-x: hidden;
}

.hot-search,
.history-section {
  padding: 30rpx 20rpx;
  border-bottom: 1rpx solid #eee;
  width: 100%;
  box-sizing: border-box;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
}

.clear-history {
  font-size: 26rpx;
  color: #999;
}

.hot-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.hot-tag {
  padding: 16rpx 30rpx;
  background: #f0f0f0;
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  width: 100%;
  box-sizing: border-box;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  width: 100%;
  box-sizing: border-box;
  min-width: 0;
}

.time-icon {
  font-size: 30rpx;
  color: #999;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.history-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  min-width: 0;
}

.delete-btn {
  font-size: 40rpx;
  color: #999;
  width: 60rpx;
  text-align: center;
  flex-shrink: 0;
}

.empty-history {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

.container,
.container view,
.container scroll-view,
.container text,
.container input,
.container image {
  max-width: 100vw;
  box-sizing: border-box;
}
