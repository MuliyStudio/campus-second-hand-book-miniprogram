/* pages/book-detail/book-detail.wxss */
page {
  background: #f5f5f5;
  min-height: 100vh;
  padding: 0;
  margin: 0;
  width: 100vw;
  overflow-x: hidden;
  box-sizing: border-box;
}

/* 容器 */
.container {
  width: 100vw;
  min-height: 100vh;
  background: #f5f5f5;
  position: relative;
  overflow-x: hidden;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 300rpx 0;
  color: #999;
  font-size: 28rpx;
  width: 100vw;
  box-sizing: border-box;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.loading-text {
  color: #666;
  font-size: 28rpx;
  margin-top: 16rpx;
}

/* 返回按钮 */
.back-btn {
  position: fixed;
  top: 40rpx;
  left: 30rpx;
  width: 60rpx;
  height: 60rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  transition: all 0.2s ease;
}

.back-btn:active {
  background: rgba(0, 0, 0, 0.8);
  transform: scale(0.95);
}

.back-icon {
  font-size: 36rpx;
  color: white;
  font-weight: bold;
  line-height: 1;
}

/* 书籍图片 */
.book-image-container {
  width: 100vw;
  height: 450rpx;
  position: relative;
  background: linear-gradient(135deg, #e0e0e0 0%, #f0f0f0 100%);
  overflow: hidden;
  box-sizing: border-box;
  flex-shrink: 0;
}

/* 轮播图样式 */
.book-swiper {
  width: 100vw;
  height: 100%;
}

.book-image {
  width: 100vw;
  height: 100%;
  display: block;
  object-fit: cover;
  box-sizing: border-box;
}

/* 图片计数器 */
.book-image-counter {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  padding: 8rpx 20rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 20rpx;
  backdrop-filter: blur(10rpx);
  z-index: 10;
  box-sizing: border-box;
}

.counter-text {
  font-size: 24rpx;
  color: white;
  font-weight: 600;
}

/* 书籍状态标签 */
.book-status-tag {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: white;
  background: #07c160;
  z-index: 10;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.3);
}

.status-text {
  font-size: 24rpx;
  font-weight: 600;
}

/* 内容区域 - 使用flex布局自动撑开 */
.content-area {
  width: 100vw;
  background: #f5f5f5;
  margin-top: -30rpx;
  border-radius: 30rpx 30rpx 0 0;
  position: relative;
  z-index: 1;
  box-sizing: border-box;
  overflow-x: hidden;
  -webkit-overflow-scrolling: touch;
  flex: 1;
  overflow-y: auto;
  padding-bottom: 140rpx; /* 为底部操作栏留出足够空间 */
}

/* 卡片通用样式 - 统一整合风格 */
.book-basic-card,
.description-card,
.seller-card,
.seller-books-card,
.no-other-books {
  background: transparent;
  border-radius: 0;
  margin: 0;
  padding: 28rpx 28rpx 20rpx 28rpx;
  box-shadow: none;
  border: none;
  border-bottom: 1rpx solid #f0f0f0;
  box-sizing: border-box;
  width: 100%;
}

/* 第一个卡片顶部增加间距 */
.book-basic-card {
  padding-top: 20rpx;
}

/* 最后一个卡片移除底部边框并增加底部边距 */
.seller-card {
  border-bottom: none;
  margin-bottom: 20rpx;
}

/* 书籍基本信息 */
.book-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 28rpx;
  gap: 20rpx;
  width: 100%;
  box-sizing: border-box;
  padding: 0 8rpx;
}

.book-title {
  flex: 1;
  font-size: 38rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  min-height: 106rpx;
}

.book-price {
  font-size: 44rpx;
  color: #ff5a5f;
  font-weight: 800;
  flex-shrink: 0;
  font-family: Arial, sans-serif;
  background: linear-gradient(135deg, #ff5a5f 0%, #ff3b5c 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.book-meta {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-bottom: 28rpx;
  width: 100%;
  box-sizing: border-box;
  padding: 0 8rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  width: 100%;
  box-sizing: border-box;
  background: #fafafa;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
}

.meta-label {
  font-size: 26rpx;
  color: #999;
  font-weight: 500;
  min-width: 120rpx;
  flex-shrink: 0;
}

.meta-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.book-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  width: 100%;
  box-sizing: border-box;
  margin-top: 12rpx;
  padding: 0 8rpx;
}

.book-tag {
  padding: 8rpx 18rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  box-sizing: border-box;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.book-tag.course {
  background: linear-gradient(135deg, #e6f3ff 0%, #d4edff 100%);
  color: #2a6cd6;
  border: none;
  box-shadow: 0 2rpx 6rpx rgba(42, 108, 214, 0.1);
}

.book-tag.condition {
  background: linear-gradient(135deg, #fff7e6 0%, #ffecc9 100%);
  color: #fa8c16;
  border: none;
  box-shadow: 0 2rpx 6rpx rgba(250, 140, 22, 0.1);
}

.tag-text {
  font-size: 24rpx;
  font-weight: 600;
}

/* 书籍描述 */
.description-card {
  margin-top: 0;
  width: 100%;
  box-sizing: border-box;
}

.description-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
  position: relative;
}

.description-title::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 0;
  width: 80rpx;
  height: 2rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.description-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  word-break: break-word;
  white-space: pre-line;
  min-height: 40rpx;
  padding: 0 8rpx;
}

/* 卖家信息 */
.seller-card {
  margin-top: 0;
  width: 100%;
  box-sizing: border-box;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 28rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
  position: relative;
}

.section-title::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 0;
  width: 80rpx;
  height: 2rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.seller-info {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 28rpx;
  width: 100%;
  box-sizing: border-box;
  padding: 0 8rpx;
  cursor: pointer;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.seller-info::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%);
  border-radius: 16rpx;
  opacity: 0;
  transition: opacity 0.3s ease;
  z-index: -1;
}

.seller-info:active::before {
  opacity: 1;
}

.seller-info:active {
  transform: scale(0.98);
}

.seller-avatar {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  border: 3rpx solid #fff;
  flex-shrink: 0;
  background: transparent;
  box-sizing: border-box;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.seller-details {
  flex: 1;
  min-width: 0;
  width: 100%;
  box-sizing: border-box;
}

.seller-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 18rpx;
  flex-wrap: nowrap;
  width: 100%;
  box-sizing: border-box;
  justify-content: space-between;
}

.seller-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex-shrink: 0;
  max-width: 200rpx;
}

/* 认证标签 - 与个人信息页面一致 */
.verified-badge {
  display: flex;
  align-items: center;
  gap: 4rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 600;
  white-space: nowrap;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.2);
}

.verified-badge .verified-icon {
  font-size: 18rpx;
  font-weight: bold;
  line-height: 1;
}

.verified-badge .verified-text {
  font-size: 20rpx;
  line-height: 1;
}

.view-profile-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
  border-radius: 50%;
  flex-shrink: 0;
  transition: all 0.3s ease;
}

.arrow-icon {
  font-size: 32rpx;
  color: #667eea;
  font-weight: 300;
  line-height: 1;
}

.seller-info:active .view-profile-arrow {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  transform: scale(0.9);
}

.seller-info:active .arrow-icon {
  color: white;
}

/* 卖家位置信息 */
.seller-location {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 28rpx;
  width: 100%;
  box-sizing: border-box;
  align-items: flex-start;
}

.location-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 18rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  border: none;
  background: linear-gradient(135deg, #f5f5f5 0%, #ebebeb 100%);
  color: #666;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.08);
  box-sizing: border-box;
  height: 48rpx;
  line-height: 1;
  flex-shrink: 0;
}

/* 卖家统计数据 */
.seller-stats {
  display: flex;
  align-items: center;
  gap: 40rpx;
  width: 100%;
  box-sizing: border-box;
  padding-top: 24rpx;
  padding: 0 8rpx;
  border-top: 2rpx solid #f0f0f0;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  box-sizing: border-box;
  flex-direction: column;
  text-align: center;
  flex: 1;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 800;
  color: #1a1a1a;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: Arial, sans-serif;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  font-weight: 600;
  margin-top: 4rpx;
}

/* 私信卖家按钮 */
.contact-btn {
  width: 100%;
  padding: 24rpx 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 16rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  transition: all 0.3s ease;
  box-sizing: border-box;
  border: none;
  margin-top: 28rpx;
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.4);
  height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.contact-btn:active {
  background: linear-gradient(135deg, #5a6fd8 0%, #6a4891 100%);
  transform: scale(0.97);
  box-shadow: 0 3rpx 10rpx rgba(102, 126, 234, 0.4);
}

.contact-text {
  font-size: 32rpx;
  font-weight: 700;
}

/* 卖家其他书籍 */
.seller-books-card {
  margin-top: 0;
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.seller-books-scroll {
  width: 100%;
  white-space: nowrap;
  box-sizing: border-box;
}

.seller-books-list {
  display: inline-flex;
  gap: 20rpx;
  padding-right: 20rpx;
  box-sizing: border-box;
}

.seller-book-item {
  width: 180rpx;
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  border: 2rpx solid #f0f0f0;
  transition: all 0.3s ease;
  flex-shrink: 0;
  box-sizing: border-box;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.seller-book-item:active {
  transform: scale(0.97);
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.12);
  border-color: #667eea;
}

.seller-book-cover {
  width: 180rpx;
  height: 120rpx;
  object-fit: cover;
  background: linear-gradient(135deg, #e0e0e0 0%, #f0f0f0 100%);
  display: block;
  box-sizing: border-box;
}

.seller-book-info {
  padding: 16rpx;
  white-space: normal;
  background: white;
  box-sizing: border-box;
}

.seller-book-title {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 8rpx;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  height: 68rpx;
  word-break: break-word;
}

.seller-book-price {
  display: block;
  font-size: 30rpx;
  color: #ff5a5f;
  font-weight: 800;
  font-family: Arial, sans-serif;
  background: linear-gradient(135deg, #ff5a5f 0%, #ff3b5c 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 无其他书籍提示 */
.no-other-books {
  margin-top: 0;
  margin-bottom: 20rpx;
  text-align: center;
  padding: 80rpx 0;
  background: linear-gradient(135deg, #fafafa 0%, #f5f5f5 100%);
  border-radius: 16rpx;
  border: 2rpx dashed #e8e8e8;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  width: 100%;
  box-sizing: border-box;
}

.no-books-icon {
  font-size: 100rpx;
  color: #d9d9d9;
  margin-bottom: 24rpx;
  opacity: 0.5;
  filter: grayscale(0.5);
}

.no-books-text {
  font-size: 28rpx;
  color: #bbb;
  font-weight: 600;
}

/* 底部安全空间 */
.bottom-safe-area {
  width: 100%;
  height: 160rpx; /* 增加安全空间高度，避免内容被遮挡 */
  box-sizing: border-box;
  flex-shrink: 0;
}

/* 底部操作栏 - 根据图片样式重新设计 */
.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: white;
  padding: 20rpx 0;
  border-top: 1rpx solid #e0e0e0;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 1000;
  box-sizing: border-box;
  width: 100vw;
  height: 140rpx; /* 增加高度 */
  padding-bottom: env(safe-area-inset-bottom, 0);
  min-height: 140rpx;
}

.action-buttons {
  display: flex;
  align-items: center;
  gap: 16rpx;
  width: 100%;
  box-sizing: border-box;
  height: 100rpx;
  padding:20rpx;
}

/* 收藏和分享按钮样式 - 根据图片设计 */
.action-btn.favorite,
.action-btn.share {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100rpx; /* 调整宽度 */
  height: 100rpx; /* 增加高度 */
  background: white;
  border-radius: 12rpx;
  border: 1rpx solid #e0e0e0;
  transition: all 0.2s ease;
  box-sizing: border-box;
  flex-shrink: 0;
  padding: 0;
  flex: 0 0 100rpx;
}

.action-btn.favorite:active,
.action-btn.share:active {
  background: #f8f8f8;
  transform: scale(0.95);
  border-color: #d9d9d9;
}

.action-btn.favorite.active {
  border-color: #ff5a5f;
  background: #fff5f5;
}

.btn-icon-container {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 50rpx;
  height: 50rpx;
  margin-bottom: 8rpx;
}

.btn-icon {
  font-size: 40rpx;
  color: #666;
  transition: all 0.2s ease;
  display: block;
  line-height: 1;
}

.action-btn.favorite.active .btn-icon {
  color: #ff5a5f;
}

.btn-text {
  font-size: 24rpx; /* 增大字体 */
  color: #666;
  font-weight: 500;
  transition: all 0.2s ease;
}

.action-btn.favorite.active .btn-text {
  color: #ff5a5f;
}


.action-btn.reserve {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100rpx;
  background: linear-gradient(135deg, #ff9c00 0%, #ff6b00 100%);
  color: white;
  border-radius: 12rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.2s ease;
  box-sizing: border-box;
  border: none;
  padding: 0 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 0, 0.3);
  min-width: 0;
  overflow: hidden;
  width: 100%;
  max-width: none;
}

.action-btn.reserve:active {
  background: linear-gradient(135deg, #e68a00 0%, #e05a00 100%);
  transform: scale(0.98);
  box-shadow: 0 2rpx 6rpx rgba(255, 107, 0, 0.3);
}

.action-btn.status-reserved,
.action-btn.status-sold,
.action-btn.status-unavailable {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100rpx;
  background: linear-gradient(135deg, #ff9c00 0%, #ff6b00 100%);
  color: white;
  border-radius: 12rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.2s ease;
  box-sizing: border-box;
  border: none;
  padding: 0 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 0, 0.3);
  min-width: 0;
  overflow: hidden;
  width: 100%;
  max-width: none;
}

.action-btn.status-reserved:active,
.action-btn.status-sold:active,
.action-btn.status-unavailable:active {
  background: linear-gradient(135deg, #e68a00 0%, #e05a00 100%);
  transform: scale(0.98);
  box-shadow: 0 2rpx 6rpx rgba(255, 107, 0, 0.3);
}

/* 取消订单按钮样式 */
.action-btn.status-cancel {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100rpx;
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  color: white;
  border-radius: 12rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.2s ease;
  box-sizing: border-box;
  border: none;
  padding: 0 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(239, 68, 68, 0.3);
  min-width: 0;
  overflow: hidden;
  width: 100%;
  max-width: none;
}

.action-btn.status-cancel:active {
  background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
  transform: scale(0.98);
  box-shadow: 0 2rpx 6rpx rgba(239, 68, 68, 0.3);
}

.status-text {
