/* pages/my-upload/my-upload.wxss */
/* 全局样式重置 */
page, view, text, image, button, input, textarea, navigator, swiper, swiper-item {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

.container {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 20rpx;
  width: 100%;
  padding-left: 0;
  padding-right: 0;
  margin: 0;
}

/* 顶部导航 */
.header {
  background: #ffffff;
  padding: 30rpx 20rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  width: 100%;
  margin: 0;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  line-height: 1.2;
}

/* 类型切换标签 */
.type-tabs {
  display: flex;
  background: #ffffff;
  border-bottom: 1rpx solid #e0e0e0;
  width: 100%;
  margin: 0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666666;
  position: relative;
  cursor: pointer;
}

.tab-item.active {
  color: #2196F3;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #2196F3;
  border-radius: 2rpx;
}

/* 发布按钮 */
.publish-btn {
  margin: 20rpx;
  padding: 24rpx 20rpx;
  background: linear-gradient(135deg, #2196F3, #1976D2);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: #ffffff;
  cursor: pointer;
  box-shadow: 0 2rpx 8rpx rgba(33, 150, 243, 0.3);
  transition: all 0.2s;
  width: calc(100% - 40rpx);
  margin-left: 20rpx;
  margin-right: 20rpx;
}

.publish-btn:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 4rpx rgba(33, 150, 243, 0.3);
}

.btn-icon {
  font-size: 36rpx;
  line-height: 1;
  font-weight: 300;
}

.btn-text {
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.2;
}

/* 内容区域 */
.content-section {
  margin-top: 20rpx;
  width: 100%;
}



/* 列表容器 */
.list-container {
  padding: 0 20rpx;
  width: 100%;
  margin: 0;
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 0;
  font-size: 24rpx;
  color: #999999;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  text-align: center;
  background: #ffffff;
  border-radius: 12rpx;
  margin-top: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.empty-icon {
  font-size: 60rpx;
  color: #cccccc;
  line-height: 1;
  margin-bottom: 20rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.2;
  margin-bottom: 20rpx;
}

.empty-btn {
  padding: 12rpx 24rpx;
  background: #2196F3;
  color: #ffffff;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
}

.empty-btn:active {
  background: #1976D2;
  transform: scale(0.95);
}

/* 书籍列表 */
.book-list,
.material-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 100%;
}

/* 书籍/资料项 */
.book-item,
.material-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.2s;
  width: 100%;
}

.book-item:active,
.material-item:active {
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transform: translateY(-2rpx);
}

/* 头部 */
.book-header,
.material-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
  width: 100%;
}

.book-title,
.material-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  word-break: break-word;
  margin-right: 16rpx;
}

.book-status {
  font-size: 20rpx;
  font-weight: 600;
  color: #ffffff;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.book-status:empty {
  display: none;
}

.book-status:not(.sold):not(.reserved) {
  background: #4CAF50;
}

.book-status.reserved {
  background: #FF9800;
}

.book-status.sold {
  background: #FA5151;
}

.material-type {
  font-size: 20rpx;
  font-weight: 600;
  color: #ffffff;
  background: #2196F3;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

/* 信息区域 */
.book-info,
.material-info {
  margin-bottom: 16rpx;
  width: 100%;
}

.info-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 12rpx;
  width: 100%;
}

.author,
.publisher,
.views,
.downloads,
.favorites,
.date {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.2;
  opacity: 0.9;
}

.divider {
  font-size: 20rpx;
  color: #cccccc;
  line-height: 1;
  font-weight: 700;
  opacity: 0.5;
}

/* 标签 */
.size-tag,
.price-tag,
.free-tag {
  font-size: 20rpx;
  font-weight: 500;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  line-height: 1.2;
  white-space: nowrap;
  flex-shrink: 0;
}

.size-tag {
  background: rgba(245, 158, 11, 0.1);
  color: #f59e0b;
  border: 1rpx solid rgba(245, 158, 11, 0.2);
}

.price-tag {
  background: rgba(250, 81, 81, 0.1);
  color: #FA5151;
  border: 1rpx solid rgba(250, 81, 81, 0.2);
}

.free-tag {
  background: rgba(7, 193, 96, 0.1);
  color: #07C160;
  border: 1rpx solid rgba(7, 193, 96, 0.2);
}

/* 操作按钮 */
.book-actions,
.material-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
  width: 100%;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 8rpx;
  cursor: pointer;
  transition: all 0.2s;
  border: 1rpx solid transparent;
}

/* 书籍操作按钮调整 */
.book-actions .action-btn {
  flex: 1;
}

.action-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.edit {
  background: rgba(33, 150, 243, 0.1);
  color: #2196F3;
  border-color: rgba(33, 150, 243, 0.2);
}

.mark-sold {
  background: rgba(250, 81, 81, 0.1);
  color: #FA5151;
  border-color: rgba(250, 81, 81, 0.2);
}

.relist {
  background: rgba(7, 193, 96, 0.1);
  color: #07C160;
  border-color: rgba(7, 193, 96, 0.2);
}

.delete {
  background: rgba(239, 68, 68, 0.1);
  color: #ef4444;
  border-color: rgba(239, 68, 68, 0.2);
}

.online {
  background: rgba(7, 193, 96, 0.1);
  color: #07C160;
  border-color: rgba(7, 193, 96, 0.2);
}

.offline {
  background: rgba(245, 158, 11, 0.1);
  color: #f59e0b;
  border-color: rgba(245, 158, 11, 0.2);
}