page {
  background: #f8fafc;
  height: 100vh;
}

.container {
  min-height: 100vh;
  padding: 0 20rpx 40rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0 30rpx;
  background: #f8fafc;
  position: sticky;
  top: 0;
  z-index: 10;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
  letter-spacing: 1rpx;
}

.scroll-view {
  height: 100vh;
  box-sizing: border-box;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.search-header {
  display: flex;
  align-items: center;
  gap: 15rpx;
  margin-bottom: 30rpx;
}

.search-header .header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  letter-spacing: 1rpx;
  flex-shrink: 0;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: white;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  border: 2rpx solid #eef2ff;
  transition: all 0.2s;
}

.back-btn:active {
  background: #f8faff;
  border-color: #667eea;
  transform: translateY(-2rpx);
}

.back-icon {
  font-size: 60rpx;
  color: #667eea;
  line-height: 1;
  font-weight: 300;
}

.search-container {
  flex: 1;
}

.search-box {
  background: white;
  border-radius: 20rpx;
  padding: 24rpx 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  border: 2rpx solid #eef2ff;
  transition: all 0.3s ease;
}

.search-box:active {
  border-color: #667eea;
  background: #f8faff;
  transform: translateY(-2rpx);
}

.search-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  color: #667eea;
}

.search-text {
  font-size: 30rpx;
  color: #999;
  flex: 1;
}

.section {
  margin-bottom: 50rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.section-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.refresh-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: white;
  border-radius: 20rpx;
  border: 2rpx solid #eef2ff;
  transition: all 0.3s ease;
  font-size: 26rpx;
}

.refresh-btn:active {
  transform: scale(0.95);
  background: #f0f4ff;
  border-color: #667eea;
}

.refresh-icon {
  font-size: 28rpx;
  color: #667eea;
}

.refresh-text {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.college-scroll,
.major-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.college-list,
.major-list {
  display: flex;
  gap: 20rpx;
  width: max-content;
  padding: 10rpx 0;
}

.college-item {
  padding: 20rpx 30rpx;
  background: white;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  border: 2rpx solid #eef2ff;
  transition: all 0.3s ease;
  flex-shrink: 0;
  text-align: center;
  min-width: 200rpx;
  white-space: normal;
  word-break: break-all;
}

.college-item.active {
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-color: #667eea;
  color: white;
  font-weight: 600;
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 30rpx rgba(102, 126, 234, 0.2);
}

.college-name {
  font-size: 28rpx;
  line-height: 1.4;
  display: block;
}

.college-item.active .college-name {
  color: white;
}

.major-item {
  padding: 16rpx 24rpx;
  border-radius: 20rpx;
  background: white;
  transition: all 0.3s ease;
  border: 2rpx solid #eef2ff;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  flex-shrink: 0;
  white-space: nowrap;
}

.major-item.active {
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-color: #667eea;
  font-weight: 600;
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 30rpx rgba(102, 126, 234, 0.2);
}

.major-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.major-item.active .major-name {
  color: white;
}

.books-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 30rpx;
}

.book-item {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
}

.book-item:active {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 30rpx rgba(102, 126, 234, 0.1);
  border-color: #667eea;
}

.book-image-container {
  position: relative;
  width: 100%;
  height: 300rpx;
  overflow: hidden;
}

.book-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}

.book-item:active .book-image {
  transform: scale(1.05);
}

.book-status {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 500;
  color: white;
  background: #4CAF50;
}

.book-status.reserved {
  background: #ff9800;
}

.book-condition {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: white;
  box-shadow: 0 3rpx 10rpx rgba(0, 0, 0, 0.2);
}

.condition-new {
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.condition-good {
  background: linear-gradient(135deg, #4CAF50, #45a049);
}

.condition-normal {
  background: linear-gradient(135deg, #ff9800, #f57c00);
}

.book-info {
  padding: 20rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  background: #ffffff;
}

.book-title-row {
  width: 100%;
  margin-bottom: 2rpx;
}

.book-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  letter-spacing: 0.5rpx;
  min-height: 40rpx;
}

.book-price-section {
  width: 100%;
  margin-top: 8rpx;
  padding-top: 8rpx;
  border-top: 1rpx solid #eef2ff;
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.book-price {
  font-size: 34rpx;
  color: #ff6b6b;
  font-weight: 800;
  letter-spacing: 1rpx;
  line-height: 1.2;
}

.book-original-price {
  font-size: 24rpx;
  color: #999;
  text-decoration: line-through;
}

.seller-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
  padding-top: 8rpx;
  border-top: 1rpx solid #eef2ff;
}

.seller-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 2rpx solid #eef2ff;
  flex-shrink: 0;
}

.seller-details {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.seller-name {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.seller-location {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.location-icon {
  font-size: 20rpx;
}

.location-text {
  font-size: 22rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.load-more {
  text-align: center;
  padding: 40rpx 0;
  color: #667eea;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  transition: all 0.3s ease;
  background: white;
  border-radius: 20rpx;
  margin-top: 20rpx;
  border: 2rpx solid #eef2ff;
}

.load-more:active {
  opacity: 0.7;
  transform: translateY(2rpx);
  border-color: #667eea;
}

.load-icon {
  font-size: 24rpx;
  animation: bounce 2s infinite;
}

@keyframes bounce {
  0%, 20%, 50%, 80%, 100% {transform: translateY(0);}
  40% {transform: translateY(-10rpx);}
  60% {transform: translateY(-5rpx);}
}

.no-more {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
  background: white;
  border-radius: 20rpx;
  margin-top: 20rpx;
}

.no-data {
  text-align: center;
  padding: 100rpx 0;
  background: white;
  border-radius: 20rpx;
  margin-top: 20rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
  color: #ccc;
  display: block;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: #666;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.empty-tip {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.publish-btn {
  width: 300rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin: 0 auto;
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
  border: none;
}

.publish-btn:active {
  transform: scale(0.95);
  box-shadow: 0 3rpx 10rpx rgba(102, 126, 234, 0.4);
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #eef2ff;
  border-top: 4rpx solid #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #667eea;
}

.safe-area {
  height: env(safe-area-inset-bottom, 0);
  margin-bottom: 20rpx;
}

@media (max-width: 375px) {
  .container {
    padding: 0 16rpx 32rpx;
  }
  
  .college-item {
    padding: 16rpx 20rpx;
    min-width: 180rpx;
  }
  
  .college-name {
    font-size: 24rpx;
  }
  
  .major-item {
    padding: 12rpx 20rpx;
  }
  
  .major-name {
    font-size: 24rpx;
  }
  
  .books-grid {
    gap: 20rpx;
  }
  
  .book-image-container {
    height: 250rpx;
  }
  
  .book-info {
    padding: 16rpx;
    gap: 6rpx;
  }
  
  .book-title {
    font-size: 26rpx;
  }
  
  .book-price {
    font-size: 30rpx;
  }
  
  .seller-avatar {
    width: 40rpx;
    height: 40rpx;
  }
  
  .seller-name {
    font-size: 22rpx;
  }
  
  .location-text {
    font-size: 20rpx;
  }
}
