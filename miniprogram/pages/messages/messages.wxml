<!-- pages/messages/messages.wxml -->
<view class="container">
  <!-- 未登录提示 -->
  <view class="login-prompt" wx:if="{{!isLoggedIn}}">
    <view class="login-content">
      <text class="login-icon">👤</text>
      <text class="login-text">请先登录</text>
      <button class="login-btn" bindtap="goToLogin">立即登录</button>
    </view>
  </view>

  <view wx:else>
    <!-- 顶部标题栏 -->
    <view class="header">
      <view class="header-content">
        <view class="title-section">
          <text class="title">消息中心</text>
          <view class="unread-indicator" wx:if="{{unreadCount > 0}}">
            <text class="unread-count">{{unreadCount}}</text>
            <text class="unread-text">条未读消息</text>
          </view>
          <view class="unread-indicator" wx:else>
            <text class="no-unread-text">暂无未读消息</text>
          </view>
        </view>
        
        <!-- 操作按钮组 -->
        <view class="header-actions">
          <view class="header-action-btn" bindtap="clearMessages">
            <view class="action-icon-box">
              <text class="action-icon">🗑️</text>
            </view>
            <text class="action-text">清空</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 标签栏 -->
    <view class="tab-bar">
      <view 
        class="tab-item {{activeTab === 'system' ? 'active' : ''}}" 
        bindtap="switchTab"
        data-tab="system"
      >
        <view class="tab-content">
          <text class="tab-text">系统消息</text>
          <view class="tab-badge" wx:if="{{systemUnreadCount > 0}}">
            <text class="badge-text">{{systemUnreadCount}}</text>
          </view>
        </view>
        <view class="tab-indicator" wx:if="{{activeTab === 'system'}}"></view>
      </view>
      
      <view 
        class="tab-item {{activeTab === 'personal' ? 'active' : ''}}" 
        bindtap="switchTab"
        data-tab="personal"
      >
        <view class="tab-content">
          <text class="tab-text">个人消息</text>
          <view class="tab-badge" wx:if="{{personalUnreadCount > 0}}">
            <text class="badge-text">{{personalUnreadCount}}</text>
          </view>
        </view>
        <view class="tab-indicator" wx:if="{{activeTab === 'personal'}}"></view>
      </view>
    </view>

    <!-- 消息列表 -->
    <scroll-view 
      scroll-y 
      class="message-list"
      refresher-enabled="true"
      refresher-triggered="{{isRefreshing}}"
      bindrefresherrefresh="refreshMessages"
      bindscrolltolower="loadMoreMessages"
      refresher-background="#f8fafc"
    >
      <!-- 加载中 -->
      <view class="loading-container" wx:if="{{isLoading}}">
        <view class="loading-content">
          <view class="loading-spinner"></view>
          <text class="loading-text">消息加载中...</text>
        </view>
      </view>

      <!-- 无消息提示 -->
      <view class="empty-state" wx:if="{{!isLoading && filteredMessages.length === 0}}">
        <view class="empty-content">
          <view class="empty-icon">📭</view>
          <text class="empty-title">暂无消息</text>
          <text class="empty-tip">暂时没有新消息哦</text>
          <view class="empty-action" bindtap="loadMessages">
            <text class="empty-action-text">刷新看看</text>
          </view>
        </view>
      </view>

      <!-- 消息列表 -->
      <view class="messages-container" wx:if="{{!isLoading && filteredMessages.length > 0}}">
        <!-- 个人消息（闲鱼风格对话框模式） -->
        <block wx:if="{{activeTab === 'personal'}}">
          <block wx:for="{{filteredMessages}}" wx:key="title">
            <!-- 时间分组标题 -->
            <view class="time-section" wx:if="{{item.type === 'section'}}">
              <text class="section-title">{{item.title}}</text>
            </view>

            <!-- 聊天列表 -->
            <block wx:if="{{item.type === 'section'}}">
              <block wx:for="{{item.data}}" wx:for-item="chatItem" wx:key="userId">
                <view
                  class="chat-card {{chatItem.hasUnread ? 'unread' : 'read'}}"
                  bindtap="onChatTap"
                  data-userid="{{chatItem.userId}}"
                  data-fromuser="{{chatItem.fromUser}}"
                  data-otheropenid="{{chatItem.otherOpenid}}"
                  data-latestmessage="{{chatItem.latestMessage}}"
                >
                  <!-- 未读消息红点角标 -->
                  <view class="chat-badge" wx:if="{{chatItem.hasUnread && chatItem.unreadCount > 0}}">
                    <text class="badge-count">{{chatItem.unreadCount > 99 ? '99+' : chatItem.unreadCount}}</text>
                  </view>
                  <view class="chat-badge chat-dot" wx:elif="{{chatItem.hasUnread}}">
                    <view class="badge-dot"></view>
                  </view>

                  <!-- 用户头像 -->
                  <view class="chat-avatar">
                    <image
                      wx:if="{{chatItem.fromUser.avatar && chatItem.fromUser.avatar !== ''}}"
                      src="{{chatItem.fromUser.avatar}}"
                      class="avatar-image"
                      mode="aspectFill"
                    />
                    <image
                      wx:elif="{{chatItem.fromUser.avatarUrl && chatItem.fromUser.avatarUrl !== ''}}"
                      src="{{chatItem.fromUser.avatarUrl}}"
                      class="avatar-image"
                      mode="aspectFill"
                    />
                    <image
                      wx:else
                      src="/images/default-avatar.png"
                      class="avatar-image"
                      mode="aspectFill"
                    />
                  </view>

                  <!-- 聊天内容 -->
                  <view class="chat-content">
                    <view class="chat-header">
                      <text class="chat-name {{chatItem.hasUnread ? 'unread' : ''}}">{{chatItem.fromUser.nickname || chatItem.fromUser.name || '用户'}}</text>
                      <text class="chat-time">{{chatItem.latestMessageTime}}</text>
                    </view>
                    <view class="chat-message-row">
                      <text class="chat-message {{chatItem.hasUnread ? 'unread' : ''}}">{{chatItem.latestMessageContent}}</text>
                    </view>
                  </view>
                </view>
              </block>
            </block>
          </block>
        </block>

        <!-- 其他消息（原有模式） -->
        <block wx:else>
          <block wx:for="{{filteredMessages}}" wx:key="_id">
            <view
              class="message-card {{item.isRead ? 'read' : 'unread'}}"
              bindtap="onMessageTap"
              bindlongpress="onLongPressMessage"
              data-id="{{item._id}}"
            >
              <view class="message-badge" wx:if="{{!item.isRead}}">
                <view class="unread-dot"></view>
              </view>

              <!-- 消息图标 -->
              <view class="message-icon-container">
                <view class="message-icon" style="background-color: {{item.color}}20;">
                  <text class="icon" style="color: {{item.color}};">{{item.icon}}</text>
                </view>
              </view>

              <!-- 消息内容 -->
              <view class="message-content">
                <view class="message-header">
                  <view class="message-title-section">
                    <text class="message-title">{{item.title}}</text>
                  </view>
                  <text class="message-time">{{item.createTime}}</text>
                </view>

                <view class="message-body">
                  <text class="message-text">{{item.content}}</text>
                  <view class="message-footer" wx:if="{{item.fromUser}}">
                    <view class="user-info" bindtap="onUserInfoTap" data-user="{{item.fromUser}}">
                      <image
                        src="{{item.fromUser.avatarUrl}}"
                        class="user-avatar"
                        mode="aspectFill"
                      />
                      <text class="user-name">{{item.fromUser.nickname}}</text>
                    </view>
                  </view>
                </view>
              </view>

              <!-- 消息操作按钮：未读消息显示标记已读按钮 -->
              <view class="message-actions" wx:if="{{!item.isRead && activeTab === 'system'}}">
                <view class="action-button" bindtap="markAsRead" data-id="{{item._id}}">
                  <view class="action-icon-box-small">
                    <text class="action-icon-small">✓</text>
                  </view>
                  <text class="action-text-small">标记已读</text>
                </view>
              </view>
            </view>
          </block>
        </block>

        <!-- 加载更多 -->
        <view class="load-more" wx:if="{{isLoadingMore}}">
          <view class="loading-spinner"></view>
          <text class="loading-text">加载中...</text>
        </view>

        <!-- 没有更多数据 -->
        <view class="no-more" wx:if="{{!isLoadingMore && !hasMore && filteredMessages.length > 0}}">
          <text class="no-more-text">没有更多消息</text>
        </view>
      </view>
    </scroll-view>
  </view>
  
  <!-- 消息详情弹窗 -->
  <view class="dialog-mask" wx:if="{{showMessageDetailDialog}}" bindtap="closeMessageDetail"></view>
  <view class="dialog-container" wx:if="{{showMessageDetailDialog}}">
    <view class="dialog-content">
      <view class="dialog-header">
        <text class="dialog-title">{{selectedMessage.title}}</text>
        <view class="dialog-close" bindtap="closeMessageDetail">✕</view>
      </view>
      
      <view class="dialog-body">
        <view class="message-detail-icon" style="color: {{selectedMessage.color}};">
          <text class="detail-icon">{{selectedMessage.icon}}</text>
        </view>
        
        <view class="message-detail-content">
          <text class="detail-text">{{selectedMessage.content}}</text>
        </view>
        
        <view class="message-detail-time">
          <text class="time-label">时间：</text>
          <text class="time-value">{{selectedMessage.createTime}}</text>
        </view>
        
        <!-- 举报内容信息 -->
        <view class="report-info" wx:if="{{selectedMessage.subType === 'report' && selectedMessage.reportInfo}}">
          <view class="report-info-item">
            <text class="report-label">被举报内容：</text>
            <text class="report-value">{{selectedMessage.reportInfo.targetInfo.title || '未知内容'}}</text>
          </view>
          <view class="report-info-item">
            <text class="report-label">举报类型：</text>
            <text class="report-value">{{selectedMessage.reportInfo.reportType}}</text>
          </view>
          <view class="report-info-item">
            <text class="report-label">举报人：</text>
            <text class="report-value">{{selectedMessage.reportInfo.reporterInfo.nickName || '匿名用户'}}</text>
          </view>
          <view class="report-info-item" wx:if="{{selectedMessage.reportInfo.targetInfo.status === 'deleted'}}">
            <text class="report-value" style="color: #ff4757; font-weight: 600;">⚠️ 该内容已被删除</text>
          </view>
        </view>
      </view>
      
      <view class="dialog-footer">
        <!-- 查看详细内容按钮 - 只对举报消息且未删除时显示 -->
        <button 
          class="dialog-btn primary" 
          bindtap="goToReportedContent" 
          wx:if="{{selectedMessage.subType === 'report' && selectedMessage.reportInfo && selectedMessage.reportInfo.targetId && selectedMessage.reportInfo.targetInfo.status !== 'deleted'}}"
        >
          查看内容
        </button>
        
        <!-- 删除内容按钮 - 只对举报消息显示，仅管理员可见 -->
        <button 
          class="dialog-btn danger" 
          bindtap="deleteReportedContent" 
          wx:if="{{selectedMessage.subType === 'report' && selectedMessage.reportInfo && selectedMessage.reportInfo.targetInfo.status !== 'deleted'}}"
        >
          删除内容
        </button>
        
        <button class="dialog-btn default" bindtap="closeMessageDetail">关闭</button>
      </view>
    </view>
  </view>
</view>