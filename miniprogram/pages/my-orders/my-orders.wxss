/* pages/my-transactions/my-transactions.wxss */
/* 容器样式 */
.container {
  width: 100vw;
  min-height: 100vh;
  background: #f8f9fa;
  box-sizing: border-box;
  padding-bottom: env(safe-area-inset-bottom);
  padding-bottom: constant(safe-area-inset-bottom);
}

/* 顶部导航 */
.header {
  width: 100%;
  background: #667eea;
  color: white;
  padding: 30rpx 0;
  position: relative;
  z-index: 10;
  box-shadow: 0 2rpx 10rpx rgba(102, 126, 234, 0.3);
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 30rpx;
}

.header-title {
  flex: 1;
  text-align: center;
  font-size: 36rpx;
  font-weight: 600;
  line-height: 1.2;
}

.search-icon {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  cursor: pointer;
  opacity: 0.9;
}

.search-icon:active {
  opacity: 0.7;
  transform: scale(0.95);
}

/* 搜索框 */
.search-bar {
  padding: 20rpx 30rpx;
  background: rgba(255, 255, 255, 0.1);
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background: white;
  border-radius: 50rpx;
  padding: 10rpx 20rpx;
  gap: 10rpx;
}

.search-input {
  flex: 1;
  height: 60rpx;
  font-size: 28rpx;
  color: #333;
}

.search-btn {
  padding: 10rpx 30rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 600;
  cursor: pointer;
  white-space: nowrap;
}

.search-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

/* 类型切换标签 */
.type-tabs {
  width: 100%;
  display: flex;
  background: white;
  border-bottom: 1rpx solid #e0e0e0;
  position: sticky;
  top: 0;
  z-index: 9;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
  cursor: pointer;
  transition: all 0.3s;
  background: white;
}

.tab-item.active {
  color: #667eea;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #667eea;
  border-radius: 2rpx;
  transition: all 0.3s;
}

.tab-item:active {
  background: #f8f9fa;
}

/* 商品类型切换 */
.category-tabs {
  width: 100%;
  display: flex;
  background: white;
  border-bottom: 1rpx solid #e0e0e0;
  position: sticky;
  top: 90rpx;
  z-index: 8;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.category-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #666;
  cursor: pointer;
  transition: all 0.3s;
  background: white;
}

.category-item.active {
  color: #667eea;
  font-weight: 600;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(102, 126, 234, 0.05));
  position: relative;
}

.category-item:active {
  background: #f8f9fa;
}

/* 状态筛选 */
.status-tabs {
  width: 100%;
  display: flex;
  background: white;
  padding: 20rpx 0;
  overflow-x: auto;
  scrollbar-width: none;
  -webkit-overflow-scrolling: touch;
  position: sticky;
  top: 140rpx;
  z-index: 7;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  border-bottom: 1rpx solid #f0f0f0;
}

.status-tabs::-webkit-scrollbar {
  display: none;
}

.status-item {
  flex-shrink: 0;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: #666;
  cursor: pointer;
  transition: all 0.3s;
  border-radius: 20rpx;
  margin: 0 10rpx;
  white-space: nowrap;
  background: #f8f9fa;
  border: 1rpx solid transparent;
}

.status-item:first-child {
  margin-left: 20rpx;
}

.status-item:last-child {
  margin-right: 20rpx;
}

.status-item.active {
  background: #667eea;
  color: white;
  border-color: #667eea;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.3);
}

.status-item:active {
  transform: scale(0.95);
}

/* 内容区域 */
.content-section {
  width: 100%;
  padding: 20rpx;
  box-sizing: border-box;
  background: #f8f9fa;
  min-height: 60vh;
}

/* 加载状态 - 优化为无背景卡片 */
.loading {
  width: 100%;
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
  background: transparent;
}

/* 没有更多提示 */
.no-more {
  width: 100%;
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
  background: transparent;
}

/* 加载动画 */
.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 空状态 - 重新设计 */
.empty {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx 100rpx;
  background: transparent;
}

.empty-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.empty-illustration {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 40rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-bg-circle {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.05));
  border-radius: 50%;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    opacity: 0.8;
  }
  50% {
    transform: scale(1.05);
    opacity: 1;
  }
}

.empty-icon {
  font-size: 120rpx;
  position: relative;
  z-index: 1;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  letter-spacing: 0.5rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 48rpx;
  line-height: 1.5;
  max-width: 400rpx;
}

.empty-btn {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 20rpx 48rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
  position: relative;
  overflow: hidden;
}

.empty-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.6s ease;
}

.empty-btn:active::before {
  left: 100%;
}

.empty-btn:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

.empty-btn .btn-icon {
  font-size: 32rpx;
  animation: bounce 1s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% {
    transform: translateX(0);
  }
  50% {
    transform: translateX(4rpx);
  }
}

/* 订单列表 */
.items-list {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 订单卡片 */
.item-card {
  width: 100%;
  background: white;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s;
  border: 1rpx solid #f0f0f0;
}

.item-card:active {
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transform: translateY(-2rpx);
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #f8f9fa, #f0f0f0);
  border-bottom: 1rpx solid #e0e0e0;
}

.order-id {
  font-size: 22rpx;
  color: #666;
  font-weight: 500;
}

.order-date {
  font-size: 22rpx;
  color: #999;
}

/* 卡片内容 */
.card-content {
  padding: 20rpx;
}

/* 商品头部 */
.item-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #f0f0f0;
  position: relative;
  padding-right: 120rpx; /* 为状态标签留出空间 */
}

/* 付款提示 */
.payment-tip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 16rpx;
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), rgba(99, 102, 241, 0.05));
  border: 1rpx solid rgba(59, 130, 246, 0.2);
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.tip-icon {
  font-size: 24rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #3b82f6;
  line-height: 1.4;
}

/* 状态标签 */
.status-tag {
  position: absolute;
  top: 0;
  right: 0;
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 14rpx;
  border-radius: 6rpx;
  white-space: nowrap;
  text-align: center;
  min-width: 70rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
  z-index: 10;
  color: white;
  display: inline-block;
  line-height: 1.2;
  background-color: #07C160;
  transform: translateY(-2rpx);
}



.item-title {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  word-break: break-word;
  padding-right: 20rpx;
}

.item-status {
  font-size: 20rpx;
  font-weight: 600;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  white-space: nowrap;
  flex-shrink: 0;
  text-align: center;
  min-width: 60rpx;
}

.item-status.pending {
  background: rgba(245, 158, 11, 0.1);
  color: #f59e0b;
  border: 1rpx solid rgba(245, 158, 11, 0.2);
}

.item-status.pending_payment {
  background: rgba(59, 130, 246, 0.1);
  color: #3b82f6;
  border: 1rpx solid rgba(59, 130, 246, 0.2);
}

.item-status.completed {
  background: rgba(7, 193, 96, 0.1);
  color: #07C160;
  border: 1rpx solid rgba(7, 193, 96, 0.2);
}

.item-status.processing {
  background: rgba(139, 92, 246, 0.1);
  color: #8b5cf6;
  border: 1rpx solid rgba(139, 92, 246, 0.2);
}

.item-status.downloaded {
  background: rgba(139, 92, 246, 0.1);
  color: #8b5cf6;
  border: 1rpx solid rgba(139, 92, 246, 0.2);
}

.item-status.cancelled {
  background: rgba(239, 68, 68, 0.1);
  color: #ef4444;
  border: 1rpx solid rgba(239, 68, 68, 0.2);
}

/* 商品信息 */
.item-info {
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.label {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
  white-space: nowrap;
  flex-shrink: 0;
}

.value {
  font-size: 24rpx;
  color: #333;
  line-height: 1.4;
  flex: 1;
  word-break: break-word;
}

/* 商品底部 */
.item-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.price {
  font-size: 32rpx;
  font-weight: 700;
  color: #FA5151;
  line-height: 1.2;
}

.price.free {
  color: #07C160;
  font-size: 28rpx;
  font-weight: 600;
}

.actions {
  display: flex;
  gap: 12rpx;
  align-items: center;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.action-btn {
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s;
  border: 1rpx solid transparent;
  white-space: nowrap;
  text-align: center;
  flex-shrink: 0;
}

.action-btn:active {
  transform: scale(0.95);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.1);
}

.action-btn.primary {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  border-color: #667eea;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.3);
}

.action-btn.secondary {
  background: rgba(245, 158, 11, 0.1);
  color: #f59e0b;
  border-color: rgba(245, 158, 11, 0.2);
}

.action-btn.review {
  background: rgba(7, 193, 96, 0.1);
  color: #07C160;
  border-color: rgba(7, 193, 96, 0.2);
}

.action-btn.rebuy {
  background: rgba(239, 68, 68, 0.1);
  color: #ef4444;
  border-color: rgba(239, 68, 68, 0.2);
}

.action-btn.pay {
  background: linear-gradient(135deg, #3b82f6, #2563eb);
  color: white;
  border-color: #3b82f6;
  box-shadow: 0 2rpx 8rpx rgba(59, 130, 246, 0.3);
}

.action-btn.download {
  background: linear-gradient(135deg, #8b5cf6, #7c3aed);
  color: white;
  border-color: #8b5cf6;
  box-shadow: 0 2rpx 8rpx rgba(139, 92, 246, 0.3);
}

.action-btn.contact {
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
  border-color: rgba(102, 126, 234, 0.2);
}

.action-btn.process {
  background: linear-gradient(135deg, #8b5cf6, #7c3aed);
  color: white;
  border-color: #8b5cf6;
  box-shadow: 0 2rpx 8rpx rgba(139, 92, 246, 0.3);
}

.action-btn.delete {
  background: rgba(239, 68, 68, 0.1);
  color: #ef4444;
  border-color: rgba(239, 68, 68, 0.2);
}

.action-btn.default {
  background: rgba(155, 155, 155, 0.1);
  color: #666;
  border-color: rgba(155, 155, 155, 0.2);
}

/* 评分功能 */
.rating-section {
  padding: 20rpx;
  background: #f8f9fa;
  border-top: 1rpx solid #e0e0e0;
  margin-top: 10rpx;
}

.rating-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.rating-stars {
  display: flex;
  gap: 15rpx;
  align-items: center;
}

.star {
  font-size: 36rpx;
  color: #e5e5e5;
  cursor: pointer;
  transition: all 0.3s;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

.star.active {
  color: #ffd700;
  text-shadow: 0 2rpx 4rpx rgba(255, 215, 0, 0.5);
  transform: scale(1.1);
}

.star:active {
  transform: scale(1.2);
}

/* 橙色取消按钮 */
.action-btn.orange {
  background: linear-gradient(135deg, #f59e0b, #d97706);
  color: white;
  border-color: #f59e0b;
  box-shadow: 0 2rpx 8rpx rgba(245, 158, 11, 0.3);
}

.action-btn.orange:active {
  background: linear-gradient(135deg, #d97706, #b45309);
  transform: translateY(-2rpx);
}

.rated-text {
  font-size: 24rpx;
  color: #07C160;
  font-weight: 600;
  margin-left: 10rpx;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .header {
    padding: 25rpx 0;
  }
  
  .header-title {
    font-size: 32rpx;
  }
  
  .tab-item {
    font-size: 26rpx;
    padding: 20rpx 0;
  }
  
  .category-item {
    font-size: 24rpx;
    padding: 16rpx 0;
  }
  
  .status-item {
    padding: 10rpx 20rpx;
    font-size: 22rpx;
  }
  
  .item-title {
    font-size: 26rpx;
  }
  
  .actions {
    flex-direction: column;
    width: 100%;
  }
  
  .action-btn {
    width: 100%;
  }
  
  .item-footer {
    flex-direction: column;
    gap: 15rpx;
  }
  
  .price {
    align-self: flex-start;
  }
}