/* pages/complete-info/complete-info.wxss */
/* 全局样式重置 */
page, view, text, image, button, input, textarea, navigator, swiper, swiper-item {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

page {
  background: #f8fafc;
  min-height: 100vh;
  padding-bottom: 100rpx;
}

.container {
  min-height: 100vh;
  padding: 20rpx;
  width: 100%;
  overflow-x: hidden;
}

/* 编辑内容区域 */
.edit-content {
  width: 100%;
  box-sizing: border-box;
}

/* 分区样式 */
.section {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.1);
  border: 1rpx solid #eef2ff;
  width: 100%;
  box-sizing: border-box;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
  width: 100%;
  box-sizing: border-box;
}

/* 头像编辑 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 0;
  width: 100%;
  box-sizing: border-box;
}

.avatar-container {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid #f0f4ff;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.1);
  cursor: pointer;
  transition: all 0.3s ease;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-container:active {
  transform: scale(1.05);
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  object-fit: cover;
}

.avatar-placeholder {
  font-size: 60rpx;
  font-weight: bold;
  color: #667eea;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0f7ff;
}

.avatar-upload-icon {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #667eea;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  border: 3rpx solid white;
  box-shadow: 0 2rpx 10rpx rgba(102, 126, 234, 0.3);
}

.avatar-hint {
  font-size: 24rpx;
  color: #666;
  text-align: center;
  width: 100%;
  box-sizing: border-box;
}

/* 表单样式 */
.form-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f4ff;
  width: 100%;
  box-sizing: border-box;
}

.form-item-vertical {
  flex-direction: column;
  align-items: flex-start;
  gap: 12rpx;
  padding: 24rpx 0;
}

.form-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.form-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  width: 120rpx;
  flex-shrink: 0;
  white-space: nowrap;
  overflow: visible;
  box-sizing: border-box;
}

.form-input {
  flex: 1;
  height: 60rpx;
  font-size: 28rpx;
  color: #333;
  padding: 0 10rpx;
  border: 1rpx solid #e0e7ff;
  border-radius: 10rpx;
  background: #f8f9fa;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #667eea;
  box-shadow: 0 0 0 2rpx rgba(102, 126, 234, 0.1);
}

.form-hint {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  width: 100%;
  display: block;
}

.form-picker {
  flex: 1;
  height: 60rpx;
  font-size: 28rpx;
  color: #333;
  padding: 0 10rpx;
  border: 1rpx solid #e0e7ff;
  border-radius: 10rpx;
  background: #f8f9fa;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
}

.picker-content {
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  box-sizing: border-box;
}

.form-picker::after {
  content: '▼';
  font-size: 20rpx;
  color: #999;
  margin-left: 10rpx;
  flex-shrink: 0;
  white-space: nowrap;
  overflow: visible;
}

/* 选项行 */
.option-row {
  display: flex;
  gap: 20rpx;
  width: 100%;
  flex: 1;
}

.option-box {
  flex: 1;
  height: 60rpx;
  background: white;
  border: 1rpx solid #e0e7ff;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding: 0 16rpx;
  transition: all 0.2s ease;
  position: relative;
  cursor: pointer;
}

.option-box.active {
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.2);
}

.option-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
  opacity: 0.8;
}

.option-box.active .option-icon {
  color: white;
  opacity: 1;
}

.option-text {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  flex: 1;
}

.option-box.active .option-text {
  color: white;
  font-weight: 600;
}

.option-check {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: transparent;
  font-size: 18rpx;
  font-weight: bold;
  background: white;
  border: 1rpx solid #d1d5db;
  flex-shrink: 0;
  opacity: 0.5;
}

.option-box.active .option-check {
  background: white;
  color: #667eea;
  border-color: white;
  opacity: 1;
}

/* 保存按钮 */
.save-section {
  margin-top: 40rpx;
  margin-bottom: 40rpx;
  width: 100%;
  box-sizing: border-box;
}

.save-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin: 0 auto;
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.2);
  transition: all 0.3s ease;
  border: none;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  display: block;
  text-align: center;
  padding: 0;
}

.save-btn:active {
  transform: scale(0.98);
  box-shadow: 0 3rpx 10rpx rgba(102, 126, 234, 0.3);
}

.save-btn.disabled {
  background: #ccc;
  box-shadow: none;
  cursor: not-allowed;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .container {
    padding: 16rpx;
  }
  
  .section {
    padding: 20rpx;
  }
  
  .section-title {
    font-size: 30rpx;
  }
  
  .form-label {
    font-size: 26rpx;
    width: 100rpx;
  }
  
  .form-input,
  .form-picker {
    font-size: 26rpx;
    height: 56rpx;
  }
  
  .option-box {
    height: 56rpx;
    padding: 0 12rpx;
  }
  
  .option-icon {
    font-size: 24rpx;
    margin-right: 8rpx;
  }
  
  .option-text {
    font-size: 24rpx;
  }
  
  .save-btn {
    height: 80rpx;
    line-height: 80rpx;
    font-size: 30rpx;
    border-radius: 40rpx;
  }
}