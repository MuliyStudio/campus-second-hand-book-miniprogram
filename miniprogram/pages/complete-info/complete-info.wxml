<!-- pages/complete-info/complete-info.wxml -->
<view class="container">
  <view class="edit-content">
    <form bindsubmit="onSubmit">
      <!-- 头像编辑 -->
      <view class="section">
        <view class="section-title">头像</view>
        <view class="avatar-section">
          <view class="avatar-container" bindtap="getUserProfile">
            <image wx:if="{{avatarUrl}}" src="{{avatarUrl}}" class="avatar"></image>
            <view wx:else class="avatar-placeholder">{{nickname.charAt(0) || '我'}}</view>
            <view class="avatar-upload-icon">📷</view>
          </view>
          <text class="avatar-hint">点击更换头像</text>
        </view>
      </view>

      <!-- 基本信息 -->
      <view class="section">
        <view class="section-title">基本信息</view>
        
        <view class="form-item">
          <text class="form-label">昵称</text>
          <input 
            class="form-input" 
            name="nickname" 
            placeholder="请输入昵称" 
            value="{{ nickname }}" 
            bindinput="onInput"
            data-name="nickname"
          />
        </view>

        <view class="form-item form-item-vertical">
          <view class="form-row">
            <text class="form-label">学号</text>
            <input 
              class="form-input" 
              type="idcard" 
              name="studentId" 
              placeholder="请输入10位学号" 
              value="{{ studentId }}" 
              bindinput="onInput"
              data-name="studentId"
              maxlength="10"
            />
          </view>
        </view>

        <view class="form-item">
          <text class="form-label">年级</text>
          <picker 
            class="form-picker" 
            value="{{gradeIndex}}" 
            range="{{gradeOptions}}" 
            bindchange="onGradeChange"
          >
            <view class="picker-content">
              {{grade || '请选择年级'}}
            </view>
          </picker>
        </view>
      </view>

      <!-- 学校信息 -->
      <view class="section">
        <view class="section-title">学校信息</view>
        
        <view class="form-item">
          <text class="form-label">校区</text>
          <view class="option-row">
            <view 
              class="option-box {{ campus === '西校区' ? 'active' : '' }}" 
              data-value="西校区" 
              bindtap="onCampusChange"
            >
              <view class="option-icon">🏫</view>
              <text class="option-text">西校区</text>
              <view class="option-check {{ campus === '西校区' ? 'active' : '' }}">✓</view>
            </view>
            <view 
              class="option-box {{ campus === '东校区' ? 'active' : '' }}" 
              data-value="东校区" 
              bindtap="onCampusChange"
            >
              <view class="option-icon">🏢</view>
              <text class="option-text">东校区</text>
              <view class="option-check {{ campus === '东校区' ? 'active' : '' }}">✓</view>
            </view>
          </view>
        </view>

        <view class="form-item">
          <text class="form-label">宿舍苑栋</text>
          <picker 
            class="form-picker" 
            value="{{dormIndex}}" 
            range="{{dormOptions}}" 
            bindchange="onDormChange"
            disabled="{{isDormDisabled}}"
          >
            <view class="picker-content">
              {{dormitory || '请选择宿舍'}}{{isDormDisabled ? '(东校区默认东苑)' : ''}}
            </view>
          </picker>
        </view>

        <view class="form-item">
          <text class="form-label">学院</text>
          <picker 
            class="form-picker" 
            value="{{collegeIndex}}" 
            range="{{collegeOptions}}" 
            bindchange="onCollegeChange"
          >
            <view class="picker-content">
              {{college || '请选择学院'}}
            </view>
          </picker>
        </view>

        <view class="form-item">
          <text class="form-label">专业</text>
          <picker 
            class="form-picker" 
            value="{{majorIndex}}" 
            range="{{majorOptions}}" 
            bindchange="onMajorChange"
          >
            <view class="picker-content">
              {{major || '请选择专业'}}
            </view>
          </picker>
        </view>
      </view>

      <!-- 提交按钮 -->
      <view class="save-section">
        <button formType="submit" class="save-btn">
          确认提交
        </button>
      </view>
    </form>
  </view>
</view>