}

/* 发布帖子区域 */
.publish-section {
  background: white;
  border-radius: 12rpx;
  padding: 20rpx;
  margin: 20rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  width: 100%;
  box-sizing: border-box;
}

/* 帖子列表 */
.posts-list {
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.post-item {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

/* 帖子头部 */
.post-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
  width: 100%;
  box-sizing: border-box;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.user-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 2rpx solid #f5f5f5;
  flex-shrink: 0;
  min-width: 72rpx;
  box-sizing: border-box;
}

.user-details {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  box-sizing: border-box;
}

.user-line {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  line-height: 1.2;
}

.user-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  min-width: 0;
  flex-shrink: 1;
}

.user-college-separator {
  font-size: 24rpx;
  color: #aaa;
  margin: 0 8rpx;
  flex-shrink: 0;
}

.user-college {
  font-size: 25rpx;
  color: #888;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  min-width: 0;
  flex-shrink: 1;
}

.post-time {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
  white-space: nowrap;
  display: inline-block;
  box-sizing: border-box;
  min-width: fit-content;
  padding-left: 8rpx;
}

/* 帖子内容 */
.post-content {
  margin-bottom: 16rpx;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

.post-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
  line-height: 1.5;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  width: 100%;
  box-sizing: border-box;
}

.post-text {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
  text-overflow: ellipsis;
  width: 100%;
  box-sizing: border-box;
  white-space: normal;
  word-break: break-word;
}

/* 标签 */
.post-tags {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-top: 12rpx;
  width: 100%;
  box-sizing: border-box;
  min-width: 0;
  overflow: hidden;
}

.post-tag {
  font-size: 22rpx;
  color: #42a5f5;
  background: #e3f2fd;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 500;
  white-space: nowrap;
  flex-shrink: 0;
  display: inline-block;
  box-sizing: border-box;
  min-width: fit-content;
}

.post-type {
  font-size: 22rpx;
  color: white;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 500;
  white-space: nowrap;
  margin-left: auto;
  flex-shrink: 0;
  display: inline-block;
  box-sizing: border-box;
  min-width: fit-content;
}

.post-type.help {
  background: linear-gradient(135deg, #f56565, #ed64a6);
}

.post-type.share {
  background: linear-gradient(135deg, #4caf50, #66bb6a);
}

/* 帖子操作 */
.post-actions {
  display: flex;
  align-items: center;
  gap: 40rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
  width: 100%;
  box-sizing: border-box;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
  min-width: 0;
  box-sizing: border-box;
}

.action-item.liked {
  color: #f56565;
}

.action-icon {
  font-size: 32rpx;
  line-height: 1;
  flex-shrink: 0;
  min-width: 32rpx;
}

.action-count {
  font-size: 28rpx;
  color: #999;
  font-weight: 500;
  white-space: nowrap;
  flex-shrink: 0;
  min-width: 0;
  box-sizing: border-box;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  transition: all 0.3s ease;
  background: white;
  border-radius: 20rpx;
  margin-top: 20rpx;
  border: 1rpx solid #eee;
  width: 100%;
  box-sizing: border-box;
  white-space: nowrap;
  overflow: hidden;
}

.load-more:active {
  opacity: 0.7;
  transform: translateY(2rpx);
  border-color: #42a5f5;
}

.load-icon {
  font-size: 24rpx;
  animation: bounce 2s infinite;
  flex-shrink: 0;
  min-width: 24rpx;
}

@keyframes bounce {
  0%, 20%, 50%, 80%, 100% {transform: translateY(0);}
  40% {transform: translateY(-10rpx);}
  60% {transform: translateY(-5rpx);}
}

.no-more {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
  background: white;
  border-radius: 20rpx;
  margin-top: 20rpx;
  border: 1rpx solid #eee;
  width: 100%;
  box-sizing: border-box;
  white-space: nowrap;
  overflow: hidden;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
  background: white;
  border-radius: 20rpx;
  margin-top: 20rpx;
  border: 1rpx solid #eee;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
  color: #ddd;
  display: block;
  white-space: nowrap;
  overflow: visible;
  width: 100%;
  box-sizing: border-box;
  text-align: center;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: #666;
  margin-bottom: 16rpx;
  font-weight: 500;
  white-space: nowrap;
  overflow: visible;
  width: 100%;
  box-sizing: border-box;
  text-align: center;
}

.empty-tip {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
  white-space: nowrap;
  overflow: visible;
  width: 100%;
  box-sizing: border-box;
  text-align: center;
}

.upload-btn, .publish-post-btn {
  width: 300rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #42a5f5, #64b5f6);
  color: white;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin: 0 auto;
  box-shadow: 0 4rpx 12rpx rgba(66, 165, 245, 0.2);
  transition: all 0.3s ease;
  border: none;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  display: block;
  box-sizing: border-box;
  text-align: center;
  max-width: 100%;
  padding: 0 20rpx;
}

.upload-btn:active, .publish-post-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 6rpx rgba(66, 165, 245, 0.3);
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
  background: white;
  border-radius: 20rpx;
  margin-top: 20rpx;
  border: 1rpx solid #eee;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

.loading-text {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: #666;
  font-size: 28rpx;
  white-space: nowrap;
  overflow: visible;
  width: 100%;
  box-sizing: border-box;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .container {
    padding: 0 20rpx;
  }
  
  .status-bar,
  .title-bar,
  .search-section,
  .tab-bar,
  .content-area {
    padding-left: 20rpx;
    padding-right: 20rpx;
  }
  
  .tab-text {
    font-size: 28rpx;
  }
  
  .rank-header {
    padding: 16rpx 0;
  }
  
  .rank-title {
    font-size: 32rpx;
  }
  
  .rank-subtitle {
    font-size: 22rpx;
  }
  
  .material-title {
    font-size: 28rpx;
  }
  
  .user-name {
    font-size: 26rpx;
  }
  
  .user-tags {
    font-size: 20rpx;
  }
  
  .post-title {
    font-size: 28rpx;
  }
  
  .post-text {
    font-size: 24rpx;
  }
}