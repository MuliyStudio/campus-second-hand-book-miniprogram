  box-sizing: border-box;
}

.material-details {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #999;
  flex-wrap: wrap;
  width: 100%;
  min-width: 0;
  box-sizing: border-box;
}

.create-time {
  font-size: 22rpx;
  color: #999;
  white-space: nowrap;
  flex-shrink: 0;
  display: inline-block;
}

/* 资料操作区域 */
.material-action {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
  flex-shrink: 0;
  width: 120rpx;
