/* 安全区域 */
.safe-area-bottom {
  height: calc(env(safe-area-inset-bottom) + 20rpx);
  width: 100%;
  background: transparent;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .header {
    padding: 20rpx 24rpx;
  }
  
  .page-title {
    font-size: 32rpx;
  }
  
  .back-icon,
  .action-icon {
    font-size: 40rpx;
  }
  
  .section {
    padding: 28rpx 24rpx;
    margin-bottom: 16rpx;
  }
  
  .author-name {
    font-size: 32rpx;
  }
  
  .post-title {
    font-size: 36rpx;
  }
  
  .post-content {
    font-size: 30rpx;
  }
  
  .post-image {
    height: 280rpx;
  }
  
  .comments-title {
    font-size: 32rpx;
  }
  
  .comment-input {
    font-size: 30rpx;
  }
  
  .comment-author {
    font-size: 28rpx;
  }
  
  .comment-text {
    font-size: 28rpx;
  }
  
  .action-btn {
    padding: 10rpx 20rpx;
  }
  
  .btn-text {
    font-size: 26rpx;
  }
}

/* 平板适配 */
@media (min-width: 768px) {
  .container {
    max-width: 750px;
    margin: 0 auto;
  }
  
  .image-grid {
    grid-template-columns: repeat(3, 1fr);
  }
  
  .post-image {
    height: 280rpx;
  }
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.section {
  animation: fadeIn 0.4s ease-out;
}

.comment-item {
  animation: fadeIn 0.3s ease-out;
}

/* 滚动条样式 */
::-webkit-scrollbar {
  width: 6rpx;
  height: 6rpx;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: rgba(0, 0, 0, 0.1);
  border-radius: 6rpx;
}

::-webkit-scrollbar-thumb:hover {
  background: rgba(0, 0, 0, 0.2);
}

/* 文本选择样式 */
::selection {
  background: rgba(7, 193, 96, 0.2);
}

/* 禁用文字选择 */
.disable-select {
  user-select: none;
  -webkit-user-select: none;
  -moz-user-select: none;
  -ms-user-select: none;
}