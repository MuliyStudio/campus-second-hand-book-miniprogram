<!-- pages/login/login.wxml -->
<view class="container">


  <!-- 主要内容区域 -->
  <view class="main-content">
    <!-- 应用图标 -->
    <view class="app-logo">
      <view class="logo-circle">
        <text class="logo-text">贺院</text>
      </view>
    </view>

    <!-- 欢迎文字 -->
    <view class="welcome-section">
      <text class="welcome-text">欢迎来到贺院书驿</text>
      <text class="welcome-subtext">一站式校园资源共享平台</text>
    </view>

    <!-- 登录按钮 -->
    <view class="login-buttons">
      <!-- 微信一键登录 -->
      <button class="wechat-login-btn" bindtap="wechatLogin">
        <text class="wechat-icon">💬</text>
        <text class="wechat-text">微信一键登录</text>
      </button>
    </view>

    <!-- 协议说明 -->
    <view class="agreement-section">
      <view class="agreement-content">
        <checkbox class="agreement-checkbox" checked="true"></checkbox>
        <text class="agreement-text">
          未注册贺院书驿的手机号，登录时将自动注册，且代表您已同意以下协议：
        </text>
      </view>
      <view class="agreement-links">
        <text class="agreement-link" bindtap="viewUserAgreement">《用户服务协议》</text>
        <text class="agreement-separator">和</text>
        <text class="agreement-link" bindtap="viewPrivacyPolicy">《隐私政策》</text>
      </view>
    </view>
  </view>

  <!-- 底部版权信息 -->
  <view class="footer">
    <text class="footer-text">贺院书驿 © 2026</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading-overlay" wx:if="{{showLoading}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">登录中...</text>
    </view>
  </view>
</view>