/* pages/upload-material/upload-material.wxss */

.container {
  width: 100%;
  min-height: 100vh;
  background: #f5f5f5;
  position: relative;
}

/* 返回按钮 */
.back-btn {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: white;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}

.back-icon {
  font-size: 36rpx;
  color: #333;
  font-weight: bold;
}

/* 页面标题 */
.page-header {
  padding: 100rpx 30rpx 40rpx;
  text-align: center;
}

.page-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

/* 滚动内容区域 */
.content-area {
  background: #f5f5f5;
  min-height: calc(100vh - 200rpx);
  padding: 0 30rpx 40rpx;
  box-sizing: border-box;
}

/* 区域标题 */
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

/* 文件上传区域 */
.file-upload-section {
  margin-bottom: 40rpx;
}

.file-upload-area {
  background: white;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  padding: 40rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.upload-icon {
  font-size: 60rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #333;
}

.upload-hint {
  font-size: 20rpx;
  color: #999;
  text-align: center;
}

.file-size-hint {
  font-size: 20rpx;
  color: #666;
  margin-top: 12rpx;
  text-align: right;
}

/* 信息填写区域 */
.info-section {
  margin-bottom: 40rpx;
}

/* 表单项目 */
.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 10rpx;
  display: block;
}

.form-input {
  width: 100%;
  background: white;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 24rpx;
  color: #333;
  box-sizing: border-box;
}

.form-input::placeholder {
  color: #999;
}

.form-textarea {
  width: 100%;
  background: white;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 24rpx;
  color: #333;
  box-sizing: border-box;
  min-height: 120rpx;
}

.form-textarea::placeholder {
  color: #999;
}

.textarea-count {
  font-size: 18rpx;
  color: #999;
  text-align: right;
  margin-top: 8rpx;
}

/* 资料类型选择器 */
.type-selector {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.type-item {
  background: white;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 16rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.type-item.active {
  border-color: #667eea;
  background: #f0f7ff;
}

.type-icon {
  font-size: 32rpx;
}

.type-text {
  font-size: 20rpx;
  color: #333;
  text-align: center;
}

/* 价格输入容器 */
.price-input-container {
  position: relative;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.price-symbol {
  font-size: 24rpx;
  color: #333;
  position: absolute;
  left: 16rpx;
  z-index: 1;
}

.price-input {
  flex: 1;
  background: white;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 20rpx 20rpx 20rpx 48rpx;
  font-size: 24rpx;
  color: #333;
  box-sizing: border-box;
}

.price-input::placeholder {
  color: #999;
}

.price-hint {
  font-size: 20rpx;
  color: #999;
  white-space: nowrap;
}

/* 学院和专业选择器 */
.form-picker {
  background: white;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 24rpx;
  color: #333;
  box-sizing: border-box;
}

.picker-text {
  color: #333;
}

/* 版权承诺区域 */
.copyright-section {
  margin-bottom: 40rpx;
}

.copyright-agree {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  background: white;
  border-radius: 12rpx;
  padding: 20rpx;
}

.checkbox {
  width: 28rpx;
  height: 28rpx;
  border: 1rpx solid #ddd;
  border-radius: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.checkbox.checked {
  background: #667eea;
  border-color: #667eea;
}

.checkbox-icon {
  font-size: 18rpx;
  color: white;
  font-weight: bold;
}

.copyright-text {
  flex: 1;
  font-size: 20rpx;
  color: #666;
  line-height: 1.4;
}

/* 上传按钮容器 */
.upload-btn-container {
  margin-bottom: 30rpx;
}

.upload-btn {
  width: 100%;
  background: #667eea;
  color: white;
  border: none;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.upload-btn:disabled {
  background: #ddd;
  color: #999;
}

/* 底部安全空间 */
.bottom-safe-area {
  height: 60rpx;
  width: 100%;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .content-area {
    padding: 0 20rpx 30rpx;
  }
  
  .page-header {
    padding: 80rpx 20rpx 30rpx;
  }
  
  .page-title {
    font-size: 32rpx;
  }
  
  .file-upload-area {
    padding: 30rpx 16rpx;
  }
  
  .type-selector {
    grid-template-columns: repeat(3, 1fr);
  }
}
