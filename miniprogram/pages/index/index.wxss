/* pages/index/index.wxss */
page {
  background: linear-gradient(180deg, #f0f4ff 0%, #f8fafc 100%);
  height: 100vh;
  min-height: 100vh;
  width: 100vw;
  overflow-x: hidden;
}

.container {
  min-height: 100vh;
  box-sizing: border-box;
  width: 100%;
  position: relative;
  padding: 0;
}

.scroll-view {
  height: 100vh;
  box-sizing: border-box;
  position: relative;
  width: 100%;
  overflow-x: hidden;
  -webkit-overflow-scrolling: touch;
}

.page-header {
  padding: 0 32rpx;
  padding-top: calc(env(safe-area-inset-top, 20rpx) + 20rpx);
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding-bottom: 40rpx;
  position: relative;
}

.page-header::after {
  content: '';
  position: absolute;
  bottom: -30rpx;
  left: 0;
  right: 0;
  height: 60rpx;
  background: linear-gradient(180deg, rgba(215, 221, 250, 0.1) 0%, transparent 100%);
  border-radius: 40rpx 40rpx 0 0;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 28rpx;
}

.header-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.greeting {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 1rpx;
}

.sub-greeting {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 400;
}

.header-right {
  display: flex;
  align-items: center;
}

.time {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.15);
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  backdrop-filter: blur(10rpx);
}

.search-container {
  position: relative;
  z-index: 10;
}

.search-box {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.search-box:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-text {
  font-size: 28rpx;
  color: #999;
  flex: 1;
  font-weight: 400;
}

.swiper-section {
  padding: 40rpx 32rpx 0;
  position: relative;
  z-index: 5;
}

.swiper {
  width: 100%;
  height: 380rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.2);
}

.swiper-item {
  width: 100%;
  height: 100%;
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
}

.swiper-image {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
}

.swiper-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx 32rpx 32rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.6) 100%);
}

.swiper-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.quick-actions {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  margin: 32rpx 32rpx 0;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
  position: relative;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  width: 100%;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 12rpx;
  border-radius: 20rpx;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.action-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #f8faff;
  opacity: 0;
  transition: opacity 0.3s ease;
  border-radius: 20rpx;
}

.action-item:active::before {
  opacity: 1;
}

.action-item:active {
  transform: scale(0.95);
}

.action-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  transition: all 0.3s ease;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.1);
  position: relative;
  z-index: 1;
}

.action-item:active .action-icon {
  transform: scale(0.9);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.action-icon.publish {
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.action-icon.category {
  background: linear-gradient(135deg, #4CAF50, #45a049);
}

.action-icon.favorite {
  background: linear-gradient(135deg, #FFB347, #FFCC33);
}

.icon {
  font-size: 44rpx;
  color: white;
  line-height: 1;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.2));
}

.action-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  line-height: 1.3;
  position: relative;
  z-index: 1;
}

.section {
  padding: 40rpx 32rpx;
  width: 100%;
  box-sizing: border-box;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
  width: 100%;
}

.section-title-wrapper {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: 0.5rpx;
}

.section-subtitle {
  font-size: 24rpx;
  color: #999;
  font-weight: 400;
}

.refresh-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
}

.refresh-btn:active {
  transform: scale(0.95);
  background: #f8faff;
}

.refresh-icon {
  font-size: 26rpx;
}

.refresh-text {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

.books-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  width: 100%;
}

.book-item {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
  display: flex;
  flex-direction: column;
}

.book-item:active {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 32rpx rgba(102, 126, 234, 0.12);
}

.book-image-container {
  position: relative;
  width: 100%;
  height: 0;
  padding-bottom: 100%;
  overflow: hidden;
  background: linear-gradient(135deg, #f0f4ff 0%, #e8ecff 100%);
}

.book-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}

.book-item:active .book-image {
  transform: scale(1.05);
}

.book-status {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 6rpx 14rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  z-index: 2;
}

.book-status.available {
  background: linear-gradient(135deg, #4CAF50, #45a049);
}

.book-condition {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  padding: 6rpx 14rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: white;
  background: linear-gradient(135deg, #667eea, #764ba2);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
  z-index: 2;
}

.book-info {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  background: #ffffff;
}

.book-title-row {
  width: 100%;
}

.book-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  letter-spacing: 0.3rpx;
}

.book-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.book-author {
  font-size: 22rpx;
  color: #888;
  font-weight: 400;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
  text-overflow: ellipsis;
}

.book-price-section {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-top: 4rpx;
}

.book-price {
  font-size: 32rpx;
  color: #ff6b6b;
  font-weight: 700;
  letter-spacing: 0.5rpx;
}

.book-original-price {
  font-size: 22rpx;
  color: #bbb;
  text-decoration: line-through;
}

.load-more {
  text-align: center;
  padding: 40rpx 0;
  color: #667eea;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: #ffffff;
  border-radius: 20rpx;
  margin-top: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
}

.load-more:active {
  transform: scale(0.98);
  background: #f8faff;
}

.load-icon {
  font-size: 24rpx;
  animation: bounce 2s infinite;
}

@keyframes bounce {
  0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
  40% { transform: translateY(-8rpx); }
  60% { transform: translateY(-4rpx); }
}

.no-more {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
  background: #ffffff;
  border-radius: 20rpx;
  margin-top: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.no-data {
  text-align: center;
  padding: 80rpx 40rpx;
  background: #ffffff;
  border-radius: 20rpx;
  margin-top: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  display: block;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-16rpx); }
}

.empty-text {
  display: block;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 600;
}

.empty-tip {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.publish-btn {
  width: 280rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  margin: 0 auto;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
  border: none;
}

.publish-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.4);
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  background: #ffffff;
  border-radius: 20rpx;
  margin-top: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #eef2ff;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #667eea;
  font-weight: 500;
}

.safe-area {
  height: calc(env(safe-area-inset-bottom, 0) + 20rpx);
  width: 100%;
  box-sizing: border-box;
}

@media (max-width: 375px) {
  .page-header {
    padding: 0 24rpx;
    padding-top: calc(env(safe-area-inset-top, 20rpx) + 16rpx);
    padding-bottom: 32rpx;
  }
  
  .greeting {
    font-size: 36rpx;
  }
  
  .swiper-section {
    padding: 32rpx 24rpx 0;
  }
  
  .quick-actions {
    margin: 24rpx 24rpx 0;
    padding: 24rpx 16rpx;
  }
  
  .action-icon {
    width: 76rpx;
    height: 76rpx;
  }
  
  .icon {
    font-size: 38rpx;
  }
  
  .section {
    padding: 32rpx 24rpx;
  }
  
  .books-grid {
    gap: 20rpx;
  }
  
  .book-title {
    font-size: 26rpx;
  }
  
  .book-price {
    font-size: 28rpx;
  }
}
