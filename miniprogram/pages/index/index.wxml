<!-- pages/index/index.wxml -->
<view class="container">
  <scroll-view 
    scroll-y="true" 
    class="scroll-view" 
    scroll-top="0"
    enable-back-to-top
    scroll-with-animation
    refresher-enabled="{{true}}"
    refresher-triggered="{{isRefreshing}}"
    bindrefresherrefresh="onRefresh"
    bindscrolltolower="onReachBottom"
  >
    <view class="page-header">
      <view class="header-top">
        <view class="header-left">
          <text class="greeting">Hi, {{userInfo.nickname || '同学'}}</text>
          <text class="sub-greeting">今天想找什么书？</text>
        </view>
      </view>
      
      <view class="search-container" bindtap="goToSearch">
        <view class="search-box">
          <text class="search-icon">🔍</text>
          <text class="search-text">搜索书名、作者、出版社...</text>
        </view>
      </view>
    </view>

    <view class="swiper-section">
      <swiper 
        class="swiper" 
        indicator-dots="{{true}}"
        indicator-color="rgba(255, 255, 255, 0.5)"
        indicator-active-color="#ffffff"
        autoplay="{{true}}" 
        interval="4000" 
        duration="500"
        circular="{{true}}"
      >
        <block wx:for="{{banners}}" wx:key="_id">
          <swiper-item>
            <view class="swiper-item" bindtap="onBannerTap" data-index="{{index}}">
              <image 
                src="{{item.imageUrl}}" 
                class="swiper-image" 
                mode="aspectFill"
              ></image>
              <view class="swiper-overlay">
                <text class="swiper-title">{{item.title}}</text>
              </view>
            </view>
          </swiper-item>
        </block>
      </swiper>
    </view>

    <view class="quick-actions">
      <view class="action-grid">
        <view class="action-item" bindtap="goToPublishBook">
          <view class="action-icon publish">
            <text class="icon">📖</text>
          </view>
          <text class="action-label">发布二手书</text>
        </view>
        
        <view class="action-item" bindtap="goToCategory">
          <view class="action-icon category">
            <text class="icon">📂</text>
          </view>
          <text class="action-label">书籍分区</text>
        </view>
        
        <view class="action-item" bindtap="goToFavorites">
          <view class="action-icon favorite">
            <text class="icon">⭐</text>
          </view>
          <text class="action-label">我的收藏</text>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-header">
        <view class="section-title-wrapper">
          <text class="section-title">热门教材</text>
          <text class="section-subtitle">精选优质二手书</text>
        </view>
        <view class="refresh-btn" bindtap="refreshBooks">
          <text class="refresh-icon">🔄</text>
          <text class="refresh-text">换一批</text>
        </view>
      </view>

      <view class="books-grid">
        <block wx:for="{{recommendedBooks}}" wx:key="_id" wx:for-index="index">
          <view 
            class="book-item" 
            bindtap="goToBookDetail" 
            data-id="{{item._id || item.id}}"
            data-index="{{index}}"
          >
            <view class="book-image-container">
              <image 
                src="{{item.coverUrl || item.image}}" 
                class="book-image" 
                mode="aspectFill"
              ></image>
              <view class="book-status available" wx:if="{{item.status === 'available'}}">在售</view>
              <view class="book-condition" wx:if="{{item.conditionText}}">{{item.conditionText}}</view>
            </view>

            <view class="book-info">
              <view class="book-title-row">
                <text class="book-title">
                  {{item.title.length <= 10 ? item.title : item.title.substring(0, 10) + '...'}}
                </text>
              </view>
              
              <view class="book-meta">
                <text class="book-author" wx:if="{{item.author}}">{{item.author}}</text>
              </view>
              
              <view class="book-price-section">
                <text class="book-price">¥{{item.price}}</text>
                <text class="book-original-price" wx:if="{{item.originalPrice}}">¥{{item.originalPrice}}</text>
              </view>
            </view>
          </view>
        </block>
      </view>

      <view class="load-more" wx:if="{{hasMore && !isLoading}}" bindtap="loadMoreBooks">
        <text class="load-text">点击加载更多</text>
        <text class="load-icon">⬇️</text>
      </view>
      
      <view class="no-more" wx:if="{{!hasMore && recommendedBooks.length > 0}}">
        <text>已经到底啦~</text>
      </view>

      <view class="no-data" wx:if="{{recommendedBooks.length === 0 && !isLoading}}">
        <view class="empty-icon">📚</view>
        <text class="empty-text">暂无推荐书籍</text>
        <text class="empty-tip">成为第一个发布者吧</text>
        <button class="publish-btn" bindtap="goToPublishBook">立即发布</button>
      </view>
      
      <view class="loading-container" wx:if="{{isLoading}}">
        <view class="loading-spinner"></view>
        <text class="loading-text">加载中...</text>
      </view>
    </view>

    <view class="safe-area"></view>
  </scroll-view>
</view>
