/* components/emoji-panel/emoji-panel.wxss */
.emoji-panel-container {
  position: relative;
  width: 100%;
  max-height: 500rpx;
  pointer-events: none;
}

.emoji-panel-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.1);
  pointer-events: auto;
}

.emoji-panel {
  position: fixed;
  bottom: 140rpx;
  left: 0;
  width: 100%;
  background: white;
  border-top-left-radius: 30rpx;
  border-top-right-radius: 30rpx;
  box-shadow: 0 -10rpx 40rpx rgba(0, 0, 0, 0.1);
  pointer-events: auto;
  animation: panelSlideUp 0.3s ease-out;
  max-height: 500rpx;
  z-index: 900;
}

@keyframes panelSlideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.emoji-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #e0e0e0;
  background: white;
}

.emoji-tabs {
  display: flex;
  gap: 40rpx;
}

.emoji-tab {
  padding: 10rpx 20rpx;
  border-bottom: 4rpx solid transparent;
  transition: all 0.2s;
}

.emoji-tab.active {
  border-bottom-color: #07c160;
}

.tab-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #666;
  transition: all 0.2s;
}

.emoji-tab.active .tab-text {
  color: #07c160;
}

.emoji-panel-close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.2s;
}

.emoji-panel-close:active {
  background: rgba(0, 0, 0, 0.1);
}

.close-icon {
  font-size: 40rpx;
  color: #666;
  line-height: 1;
}

.emoji-content-container {
  position: relative;
  max-height: 400rpx;
  background: #f5f5f5;
}

.emoji-content {
  max-height: 400rpx;
  overflow-y: auto;
  background: #f5f5f5;
  -webkit-overflow-scrolling: touch;
}

.fixed-delete-btn {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  width: 80rpx;
  height: 80rpx;
  border-radius: 10rpx;
  background: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #666;
  transition: all 0.2s;
  user-select: none;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  z-index: 10;
}

.fixed-delete-btn:active {
  background: #f0f0f0;
  transform: scale(0.95);
}

.emoji-section {
  padding: 20rpx 0;
}

.emoji-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 20rpx;
  padding: 20rpx 20rpx;
}

.emoji-item {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  border-radius: 10rpx;
  transition: all 0.2s;
  user-select: none;
  background: white;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.emoji-item:active {
  background: #f0f0f0;
  transform: scale(0.95);
}

.emoji-item.delete {
  background: white;
}

.delete-icon {
  font-size: 40rpx;
  color: #666;
}

.emoji-empty {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty-text {
  color: #999;
}

/* 安全区域适配 */
@media (env(safe-area-inset-bottom)) {
  .emoji-panel {
    padding-bottom: env(safe-area-inset-bottom);
  }
}